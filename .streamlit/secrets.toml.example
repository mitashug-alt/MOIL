# Copy to .streamlit/secrets.toml for local/Codespaces runs.
# Never commit .streamlit/secrets.toml with real values.

GROQ_API_KEY = "YOUR_GROQ_API_KEY"
GROQ_MODEL = "llama-3.3-70b-versatile"
GROQ_KEY_NAME = "MOIL Macro Radar Groq Key"
GROQ_PROJECT = "MOIL Macro Radar"

TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""

# Optional search fallback for source-aware macro feed.
SERPER_API_KEY = ""

# Optional vendor/internal proxy feeds. Leave blank until licensed feeds exist.
ARGUS_API_KEY = ""
ARGUS_SIMN_FEED_URL = ""
JPC_API_KEY = ""
JPC_STEEL_FEED_URL = ""
GACC_API_KEY = ""
GACC_STEEL_EXPORTS_FEED_URL = ""
CHINA_POWER_API_KEY = ""
CHINA_POWER_STRESS_FEED_URL = ""

# Optional: used by institutional_tracker.py to convert block/bulk quantity to % equity.
MOIL_OUTSTANDING_SHARES = ""
