{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MOIL Macro Radar Observation",
  "type": "object",
  "required": ["indicator", "source_name", "source_url", "observation_date", "confidence"],
  "properties": {
    "observation_id": {"type": "string"},
    "scrape_run_id": {"type": "string"},
    "indicator": {"type": "string"},
    "country": {"type": ["string", "null"]},
    "company": {"type": ["string", "null"]},
    "product_family": {"type": ["string", "null"]},
    "ore_code": {"type": ["string", "null"]},
    "grade": {"type": ["string", "null"]},
    "region": {"type": ["string", "null"]},
    "period": {"type": ["string", "null"]},
    "effective_date": {"type": ["string", "null"]},
    "observation_date": {"type": "string"},
    "value": {"type": ["number", "null"]},
    "currency": {"type": ["string", "null"]},
    "unit": {"type": ["string", "null"]},
    "basis": {"type": ["string", "null"]},
    "source_name": {"type": "string"},
    "source_url": {"type": "string"},
    "source_type": {"type": ["string", "null"]},
    "document_hash": {"type": ["string", "null"]},
    "page_hash": {"type": ["string", "null"]},
    "extraction_method": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "data_quality": {"type": ["string", "null"]},
    "raw_text": {"type": ["string", "null"]},
    "parse_warning": {"type": ["string", "null"]}
  }
}
