{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MOIL Macro Radar Evidence Row",
  "type": "object",
  "required": ["indicator", "source_name", "data_confidence", "scoring_allowed", "raw_text"],
  "properties": {
    "evidence_id": {"type": "string"},
    "indicator": {"type": "string"},
    "period": {"type": ["string", "null"]},
    "value": {"type": ["string", "number", "null"]},
    "unit": {"type": ["string", "null"]},
    "region": {"type": ["string", "null"]},
    "source_name": {"type": "string"},
    "source_url": {"type": ["string", "null"]},
    "source_type": {"type": "string"},
    "source_tier": {"type": "integer", "minimum": 1, "maximum": 5},
    "exact_data": {"type": "boolean"},
    "publication_date": {"type": ["string", "null"]},
    "scraped_at": {"type": ["string", "null"]},
    "parser_method": {"type": ["string", "null"]},
    "parser_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "cross_source_confirmed": {"type": "boolean"},
    "data_confidence": {"type": "number", "minimum": 0, "maximum": 100},
    "confidence_weight": {"type": "number", "minimum": 0, "maximum": 1},
    "scoring_allowed": {"type": "boolean"},
    "confidence_label": {"type": "string"},
    "confidence_notes": {"type": ["string", "null"]},
    "raw_text": {"type": ["string", "null"]}
  }
}
